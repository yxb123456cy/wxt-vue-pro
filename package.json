{
  "name": "wxt-vue-pro",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "commit": "git-cz",
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "ls": "pnpm m ls"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "cz-git": "^1.13.1",
    "turbo": "^2.5.4",
    "typescript": "^5.9.2"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git",
      "useEmoji": true
    }
  }
}